# TransitSight - Environment Configuration
# Copy this file to .env and fill in your values

# Google AI Studio (Gemini API) — REQUIRED for AI predictions
# Get your API key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (optional, defaults to gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash

# Admin dashboard credentials (default: admin / admin123)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Server configuration
HOST=0.0.0.0
PORT=8000

# Database (optional, defaults to sqlite:///./transitsight.db)
DATABASE_URL=sqlite:///./transitsight.db

# Note: data.gov.my APIs (GTFS Static, GTFS Realtime, Weather) are free-tier
# and do not require API keys. The app will work with or without GEMINI_API_KEY —
# without it, rule-based fallback predictions are used.
